generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserPlan {
  FREE
  PRO
  AGENCY
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum WebsiteStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum FormStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SubmissionStatus {
  NEW
  CONTACTED
  WON
  LOST
  ARCHIVED
}

enum SpamStatus {
  CLEAN
  SUSPICIOUS
  SPAM
  BLOCKED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum SpamBucket {
  INBOX
  SUSPICIOUS
  SPAM
  BLOCKED_LOG
}

enum NotificationStatus {
  SENT
  QUEUED
  SUPPRESSED_SPAM
  SUPPRESSED_SUSPICIOUS
  FAILED
  NOT_APPLICABLE
}

enum WebsiteProtectionMode {
  OPEN
  STANDARD
  STRICT
}

enum FormType {
  CONTACT
  QUOTE_REQUEST
  NEWSLETTER
  BOOKING_ENQUIRY
  WAITLIST
  OTHER
}

enum SpamFeedbackAction {
  MARKED_SPAM
  MARKED_NOT_SPAM
}

model User {
  id                   String      @id @default(cuid())
  fullName             String
  email                String      @unique
  passwordHash         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  plan                 UserPlan    @default(FREE)
  emailVerified        DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  workspaces           Workspace[] @relation("WorkspaceOwner")
}

model Workspace {
  id            String         @id @default(cuid())
  ownerUserId   String
  workspaceName String
  plan          UserPlan       @default(FREE)
  billingStatus BillingStatus  @default(TRIALING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  websites      Website[]
  submissions   Submission[]
}

model Website {
  id                     String      @id @default(cuid())
  workspaceId            String
  websiteName            String
  websiteUrl             String
  defaultRecipientEmail  String
  allowedDomains         String[]
  defaultSuccessRedirect String?
  timezone               String?
  status                 WebsiteStatus @default(ACTIVE)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  workspace              Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  forms                  FormInbox[]
  submissions            Submission[]
  blockedEvents          BlockedEvent[]

  @@index([workspaceId])
}

model FormInbox {
  id                    String       @id @default(cuid())
  websiteId             String
  formName              String
  publicFormId          String       @unique
  endpointUrl           String?
  recipientEmails       String[]
  successRedirectUrl    String?
  spamProtectionLevel   String       @default("STANDARD")
  websiteProtectionMode WebsiteProtectionMode @default(STANDARD)
  formType              FormType     @default(CONTACT)
  honeypotFieldName     String?
  nameFieldKey          String?
  emailFieldKey         String?
  phoneFieldKey         String?
  messageFieldKey       String?
  status                FormStatus   @default(ACTIVE)
  notifyOnLowSuspicious Boolean      @default(true)
  notifyOnSuspicious    Boolean      @default(false)
  notifyOnSpam          Boolean      @default(false)
  weeklySpamSummary     Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  website               Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  submissions           Submission[]
  blockedEvents         BlockedEvent[]
  feedbackEvents        SpamFeedback[]

  @@index([websiteId])
}

model Submission {
  id               String           @id @default(cuid())
  workspaceId      String
  websiteId        String
  formId           String
  status           SubmissionStatus @default(NEW)
  spamStatus       SpamStatus       @default(CLEAN)
  spamScore        Int              @default(0)
  spamBucket       SpamBucket       @default(INBOX)
  spamReasons      Json?
  spamCheckedAt    DateTime?
  notificationStatus NotificationStatus @default(NOT_APPLICABLE)
  notificationSuppressedReason String?
  submitterName    String?
  submitterEmail   String?
  submitterPhone   String?
  messagePreview   String?
  rawFields        Json
  fieldItems       Json
  sourceUrl        String?
  pageTitle        String?
  originHeader     String?
  refererHeader    String?
  referrer         String?
  ipHash           String?
  userAgent        String?
  requestFingerprint String?
  submissionFingerprint String?
  payloadHash      String?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  website          Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  form             FormInbox        @relation(fields: [formId], references: [id], onDelete: Cascade)
  emailLogs        EmailLog[]
  spamEvents       SpamEvent[]
  feedbackEvents   SpamFeedback[]

  @@index([workspaceId, createdAt])
  @@index([websiteId, createdAt])
  @@index([formId, createdAt])
  @@index([spamStatus, createdAt])
  @@index([formId, submissionFingerprint, createdAt])
}

model EmailLog {
  id             String      @id @default(cuid())
  submissionId   String
  recipientEmail String
  emailSubject   String
  emailStatus    EmailStatus @default(PENDING)
  sesMessageId   String?
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime    @default(now())
  submission     Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model SpamEvent {
  id           String     @id @default(cuid())
  submissionId String
  reason       String
  scoreAdded   Int
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model BlockedEvent {
  id            String   @id @default(cuid())
  workspaceId   String?
  websiteId     String?
  formId        String?
  publicFormId  String?
  reason        String
  ipHash        String?
  userAgent     String?
  originHeader  String?
  refererHeader String?
  payloadSize   Int?
  fieldCount    Int?
  contentType   String?
  createdAt     DateTime @default(now())
  website       Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  form          FormInbox? @relation(fields: [formId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([formId, createdAt])
}

model SpamFeedback {
  id                     String             @id @default(cuid())
  submissionId           String
  formId                 String
  workspaceId            String
  action                 SpamFeedbackAction
  previousSpamScore      Int
  previousClassification SpamStatus
  createdAt              DateTime           @default(now())
  submission             Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  form                   FormInbox          @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([formId, createdAt])
}
